#!/usr/bin/env python3
"""
update-lists — синхронизация и генерация dnsmasq конфигов
v2: атомарное обновление nftsets (один nft -f вместо flush+restore+restart)

Использование:
  update-lists           — синхронизация (кэш 24ч)
  update-lists --force   — принудительное скачивание
  update-lists --apply   — только применить (без скачивания)
"""
import json, os, sys, time, urllib.request, urllib.error, subprocess, tempfile

CONFIG_FILE      = "/etc/gateway-ui/lists-config.json"
CACHE_DIR        = "/var/cache/gateway-ui/lists"
DNSMASQ_DIR      = "/etc/dnsmasq.d"
TUNNEL_CONF      = f"{DNSMASQ_DIR}/lists-tunnel.conf"
ZAPRET_CONF      = f"{DNSMASQ_DIR}/lists-zapret.conf"
ZAPRET_HOSTLIST  = "/opt/zapret2/ipset/zapret-hosts-user.txt"
CACHE_TTL        = 86400  # 24 hours

# Статические IP-диапазоны для туннеля (hardcoded, не резолвятся через DNS)
STATIC_TUNNEL_SUBNETS = [
    "149.154.160.0/20",  # Telegram DC1-5
    "91.108.4.0/22",     # Telegram DC
    "91.108.8.0/22",
    "91.108.56.0/22",
    "95.161.64.0/20",
]

FORCE  = "--force" in sys.argv
APPLY  = "--apply" in sys.argv

def log(msg):
    ts = time.strftime("%Y-%m-%d %H:%M:%S")
    print(f"[{ts}] {msg}", flush=True)

def load_config():
    with open(CONFIG_FILE) as f:
        return json.load(f)

def save_config(cfg):
    with open(CONFIG_FILE, "w") as f:
        json.dump(cfg, f, indent=2, ensure_ascii=False)

def cache_path(list_id):
    os.makedirs(CACHE_DIR, exist_ok=True)
    return os.path.join(CACHE_DIR, list_id + ".lst")

def needs_download(list_id):
    if FORCE:
        return True
    path = cache_path(list_id)
    if not os.path.exists(path):
        return True
    age = time.time() - os.path.getmtime(path)
    return age > CACHE_TTL

def write_static(list_id, domains):
    """Записывает inline-домены из конфига в кэш (не скачивает)."""
    path = cache_path(list_id)
    with open(path, "w") as f:
        f.write("\n".join(domains) + "\n")
    log(f"{list_id}: статический список ({len(domains)} доменов)")
    return len(domains)

def download(list_id, url):
    path = cache_path(list_id)
    log(f"Скачивание {list_id} ...")
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "gateway-ui/2.0"})
        with urllib.request.urlopen(req, timeout=30) as r:
            data = r.read().decode(errors="replace")
        with open(path, "w") as f:
            f.write(data)
        domains = parse_domains(data)
        log(f"  → {len(domains)} доменов")
        return len(domains)
    except Exception as e:
        log(f"  ✗ Ошибка: {e}")
        return None

def parse_domains(text):
    domains = []
    for line in text.splitlines():
        line = line.strip().lstrip(".")
        if not line or line.startswith("#"):
            continue
        domains.append(line)
    return domains

def read_cached(list_id):
    path = cache_path(list_id)
    if not os.path.exists(path):
        return []
    with open(path) as f:
        return parse_domains(f.read())

def generate_configs(cfg):
    tunnel_lines = [
        "# AUTO-GENERATED by update-lists — не редактировать вручную\n",
        "# tunnel: домены направляются через AWG VPN (blocked_ips)\n\n",
    ]
    zapret_lines = [
        "# AUTO-GENERATED by update-lists — не редактировать вручную\n",
        "# zapret: домены направляются через DPI bypass (zapret_ips)\n\n",
    ]

    total_tunnel = 0
    total_zapret = 0
    zapret_domains_all = []

    for lst in cfg["lists"].values():
        if not lst.get("enabled") or lst.get("mode") in ("disabled", "direct"):
            continue

        mode    = lst["mode"]
        list_id = lst["id"]
        domains = read_cached(list_id)

        if not domains:
            log(f"  ⚠ {list_id}: нет кэша, пропускаем")
            continue

        target = "blocked_ips" if mode == "tunnel" else "zapret_ips"
        lines  = tunnel_lines if mode == "tunnel" else zapret_lines

        lines.append(f"# {lst['name']} ({len(domains)} доменов)\n")
        for domain in domains:
            lines.append(f"nftset=/{domain}/4#ip#tunnel_routing#{target}\n")
        lines.append("\n")

        if mode == "tunnel":
            total_tunnel += len(domains)
        else:
            total_zapret += len(domains)
            zapret_domains_all.extend(domains)

    with open(TUNNEL_CONF, "w") as f:
        f.writelines(tunnel_lines)
    with open(ZAPRET_CONF, "w") as f:
        f.writelines(zapret_lines)

    log(f"Сгенерировано: tunnel={total_tunnel} доменов, zapret={total_zapret} доменов")
    update_nfqws2_hostlist(zapret_domains_all)

    return total_tunnel, total_zapret

def update_nfqws2_hostlist(domains):
    try:
        os.makedirs(os.path.dirname(ZAPRET_HOSTLIST), exist_ok=True)
        with open(ZAPRET_HOSTLIST, "w") as f:
            f.write("# AUTO-GENERATED by update-lists\n")
            for d in sorted(set(domains)):
                f.write(d + "\n")
        log(f"nfqws2 hostlist обновлён: {len(domains)} доменов")
    except Exception as e:
        log(f"  ✗ Ошибка обновления nfqws2 hostlist: {e}")

def atomic_nftset_reset():
    """
    Атомарно сбрасывает nftsets и восстанавливает статику.

    v2: вместо трёх отдельных вызовов nft (flush, add, add...) — один nft -f.
    nft обрабатывает файл как единую транзакцию через netlink batch.
    Нет окна между flush и restore → нет утечки трафика.

    dnsmasq НЕ перезапускается (только reload/SIGHUP):
    - Сохраняет DNS кэш
    - Сохраняет существующие nftset записи (TTL-управляемые)
    - После reload новые DNS-запросы попадают в обновлённые конфиги
    """
    # Формируем nft файл: flush + статические элементы — одна транзакция
    static_elements = ",\n            ".join(STATIC_TUNNEL_SUBNETS)
    nft_content = f"""# AUTO-GENERATED by update-lists — атомарный сброс nftsets
# Применяется как единая транзакция (netlink batch)

flush set ip tunnel_routing blocked_ips
flush set ip tunnel_routing zapret_ips

# Восстанавливаем статические IP (Telegram DC и др.)
# Эти сервисы используют hardcoded IP без DNS-резолюции
add element ip tunnel_routing blocked_ips {{
    {static_elements}
}}
"""
    # Пишем во временный файл — атомарно применяем
    with tempfile.NamedTemporaryFile(
        mode="w", suffix=".nft", prefix="gateway-reset-",
        dir="/tmp", delete=False
    ) as tmp:
        tmp.write(nft_content)
        tmp_path = tmp.name

    try:
        r = subprocess.run(
            ["nft", "-f", tmp_path],
            capture_output=True, timeout=10
        )
        if r.returncode == 0:
            log(f"nftsets сброшены атомарно, статика восстановлена "
                f"({len(STATIC_TUNNEL_SUBNETS)} подсетей)")
        else:
            err = r.stderr.decode(errors="replace").strip()
            log(f"  ✗ Ошибка nft: {err}")
    except Exception as e:
        log(f"  ✗ Исключение nft: {e}")
    finally:
        os.unlink(tmp_path)

def reload_dnsmasq():
    """
    reload (SIGHUP) вместо restart — сохраняет DNS кэш и nftset записи.

    При restart dnsmasq:
    - Кэш очищается → все клиентские DNS-запросы идут upstream заново
    - nftset записи живут только пока dnsmasq их не переустановит
    - Есть ~секундное окно без nftset записей

    При reload (SIGHUP):
    - Кэш сохраняется
    - Существующие nftset записи остаются (TTL управляет истечением)
    - Новые DNS-запросы используют обновлённый конфиг сразу
    """
    r = subprocess.run(
        ["systemctl", "reload", "dnsmasq"],
        capture_output=True, timeout=10
    )
    if r.returncode == 0:
        log("dnsmasq перезагружен (SIGHUP, кэш сохранён)")
    else:
        # Fallback: если reload не поддерживается — restart
        log("reload не сработал, пробуем restart...")
        r2 = subprocess.run(
            ["systemctl", "restart", "dnsmasq"],
            capture_output=True, timeout=15
        )
        if r2.returncode == 0:
            log("dnsmasq перезапущен (кэш сброшен)")
        else:
            log(f"  ✗ Ошибка перезапуска dnsmasq: {r2.stderr.decode()}")

def restart_nfqws2():
    r = subprocess.run(
        ["systemctl", "restart", "zapret2-nfqws2"],
        capture_output=True, timeout=15
    )
    if r.returncode == 0:
        log("zapret2-nfqws2 перезапущен")
    else:
        log(f"  ✗ Ошибка перезапуска zapret2-nfqws2: {r.stderr.decode()}")

def main():
    cfg = load_config()
    changed = False

    if not APPLY:
        for lst in cfg["lists"].values():
            if not lst.get("enabled") or lst.get("mode") in ("disabled", "direct"):
                continue
            list_id = lst["id"]
            url = lst.get("url", "")
            if not url:
                # Статический список — домены хранятся прямо в конфиге
                inline = lst.get("domains", [])
                if inline:
                    count = write_static(list_id, inline)
                    lst["domain_count"] = count
                    changed = True
            elif needs_download(list_id):
                count = download(list_id, url)
                if count is not None:
                    lst["domain_count"] = count
                    changed = True
            else:
                domains = read_cached(list_id)
                if lst.get("domain_count") != len(domains):
                    lst["domain_count"] = len(domains)
                    changed = True

    # 1. Генерируем новые dnsmasq конфиги
    generate_configs(cfg)

    # 2. Атомарно сбрасываем nftsets и восстанавливаем статику
    #    Единый nft -f = нет окна утечки трафика
    atomic_nftset_reset()

    # 3. Reload dnsmasq (SIGHUP) — применяет новые конфиги
    #    Кэш сохраняется, новые DNS-запросы заполнят nftsets
    reload_dnsmasq()

    # 4. Перезапускаем zapret с новым hostlist
    restart_nfqws2()

    cfg["last_sync"] = time.strftime("%Y-%m-%dT%H:%M:%S")
    save_config(cfg)

    log("Готово.")

if __name__ == "__main__":
    main()
