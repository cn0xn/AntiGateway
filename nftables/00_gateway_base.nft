# ── Gateway base: tunnel_routing table ──────────────────────────────────────
table ip tunnel_routing {
    set blocked_ips {
        type ipv4_addr
        flags interval
    }
    set zapret_ips {
        type ipv4_addr
        flags interval
    }
    set doh_servers {
        type ipv4_addr
        flags interval
        elements = {
            1.1.1.1, 1.0.0.1,
            8.8.8.8, 8.8.4.4,
            9.9.9.9, 9.9.9.10,
            149.112.112.112,
            94.140.14.14, 94.140.15.15,
            185.228.168.9, 185.228.169.9
        }
    }
    chain preroute_mark {
        type filter hook prerouting priority mangle; policy accept;
        ip daddr @blocked_ips meta mark set 0x00000001
    }
    chain forward_zapret {
        type filter hook forward priority filter; policy accept;
        meta mark 0x40000000 accept
        meta mark != 0x00000001 ip daddr @zapret_ips tcp dport { 80, 443 } queue flags bypass to 300
        meta mark != 0x00000001 ip daddr @zapret_ips udp dport 443 queue flags bypass to 300
    }
}
